# Conexão com o SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=NomeDoBanco
DB_USER=usuario
# Se a senha tiver caracteres especiais (ex: #, espaço), coloque entre aspas duplas
DB_PASSWORD="senha"

# Opções de conexão (true/false)
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Porta do servidor da API
PORT=3001

# Tempo (em segundos) de cache em memória dos resultados das queries
CACHE_TTL_SECONDS=300