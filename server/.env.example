# Conexão com o SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=NomeDoBanco
DB_USER=usuario
# Se a senha tiver caracteres especiais (ex: #, espaço), coloque entre aspas duplas
DB_PASSWORD="senha"

# Opções de conexão (true/false)
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Porta do servidor da API
PORT=3001

# Tempo (em segundos) de cache em memória dos resultados das queries
CACHE_TTL_SECONDS=300

# ---- Fonte de dados do relatório ----
# 'sqlserver' = lê direto do SQL Server (use no DEV e na máquina do MOTOR).
# 'supabase'  = lê o snapshot da nuvem (use no VPS de produção).
DATA_SOURCE=sqlserver

# ---- Supabase (nuvem) ----
# Dados do pooler: painel do Supabase → Settings → Database → Connection string.
# Usado pelo MOTOR (grava) e pelo backend do VPS (lê). NÃO versionar.
# Campos separados evitam problema de encoding em senhas com caracteres especiais.
SUPABASE_DB_HOST=aws-1-sa-east-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=postgres.SEU_PROJECT_REF
SUPABASE_DB_PASSWORD=sua_senha_do_banco
SUPABASE_DB_NAME=postgres
# (alternativa) SUPABASE_DB_URL=postgresql://user:senha@host:porta/postgres

# Tamanho do lote de INSERT do motor (opcional)
SYNC_BATCH_SIZE=500